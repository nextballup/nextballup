# NextBallUp alpha detector preview worker.
#
# Copy to `.env.alpha-preview.local` and fill values from Render/R2 locally.
# Do not commit the copied file and do not paste these secrets into chat.

APP_ENV=staging
APP_DEBUG=false

# Render Postgres. Prefer DATABASE_URL_RUNTIME for the nextballup_app runtime role.
DATABASE_URL=
DATABASE_URL_RUNTIME=
DATABASE_RUNTIME_USERNAME=nextballup_app
DATABASE_RUNTIME_PASSWORD=

# Render Key Value external URL. Enable external access for your current IP
# in Render before using this from your Mac.
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_DEMO_PREVIEW_QUEUE=nextballup.demo_preview
CELERY_WORKER_CONCURRENCY=1

# Cloudflare R2.
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_RAW=nextballup-alpha-raw
S3_REGION=auto

# Alpha preview gate and local artifact paths.
CV_DEMO_PREVIEW_ENABLED=false
CV_ALPHA_DETECTOR_PREVIEW_ENABLED=true
CV_DEMO_TRAINING_REPO_ROOT=../nextballup-vision-training
CV_DEMO_PREVIEW_ROOT=./local_artifacts/demo_previews
CV_DEMO_SAMPLE_FPS=12.0
CV_DEMO_MAX_SAMPLE_FPS=12.0
CV_DEMO_TIMEOUT_SECONDS=7200
WORKER_MEDIA_TEMP_DIR=./local_artifacts/alpha-demo-scratch

# Defaults already point to the checked local E-BARD alpha detector artifact.
# Override only if you move the checkpoint/eval report.
# CV_ALPHA_DETECTOR_CONFIG_PATH=../nextballup-vision-training/configs/experiments/basketball/detect/rfdetr_ebard_alpha_demo_v1.yaml
# CV_ALPHA_DETECTOR_CHECKPOINT_PATH=../nextballup-vision-training/local_artifacts/runs_alpha/runs/bb_detect_rfdetr_ebard_alpha_demo_v1/bb_detect_rfdetr_ebard_alpha_demo_v1-20260505T190931Z/checkpoints/checkpoint_best_total.pth
# CV_ALPHA_DETECTOR_EVAL_REPORT_PATH=../nextballup-vision-training/local_artifacts/runs_alpha/runs/bb_detect_rfdetr_ebard_alpha_demo_v1/bb_detect_rfdetr_ebard_alpha_demo_v1-20260505T190931Z/eval_report.json

# Worker hardening values expected in staging.
WORKER_MEDIA_SUBPROCESS_SANDBOX=true
WORKER_MEDIA_CONTAINER_SANDBOX_ENABLED=false
WORKER_MEDIA_MAX_CPU_SECONDS=7200
WORKER_MEDIA_MAX_OUTPUT_BYTES=107374182400
