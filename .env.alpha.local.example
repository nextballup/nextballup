# NextBallUp local alpha-like backend profile.
#
# Copy to `.env.alpha.local`, fill secrets if needed, then run the helper
# scripts in `scripts/local_alpha_*.sh`.
#
# Important: this intentionally keeps APP_ENV=development. The real Render
# alpha uses APP_ENV=staging, but staging refuses localhost URLs and insecure
# local cookies by design. This profile mirrors alpha behavior that matters for
# debugging while still being runnable on 127.0.0.1.

# ---- App channel ----
APP_ENV=development
APP_DEBUG=false
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Localhost-safe cookies ----
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_HOST_PREFIX=false
COOKIE_DOMAIN=

# ---- Registration gate, matching alpha behavior ----
REGISTRATION_MODE=invite_only
REGISTRATION_INVITE_CODES=LOCAL-ALPHA-CODE
REGISTRATION_EMAIL_ALLOWLIST=
RATE_LIMIT_FAIL_CLOSED=true

# ---- Database: local Docker Postgres owner connection ----
DATABASE_URL=postgresql+asyncpg://nextballup:nextballup_dev@127.0.0.1:5432/nextballup
DATABASE_URL_SYNC=postgresql://nextballup:nextballup_dev@127.0.0.1:5432/nextballup
# Leave unset for fastest local debugging. Render alpha uses nextballup_app.
DATABASE_URL_RUNTIME=
DATABASE_RUNTIME_USERNAME=nextballup_app
DATABASE_RUNTIME_PASSWORD=

# ---- Redis: local Docker Redis ----
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ---- Object storage ----
# Default: local Docker MinIO. This is fastest for API/web/worker debugging.
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_RAW=nbu-raw-video
S3_REGION=us-east-1

# To debug real R2 browser multipart behavior, replace the block above with:
# S3_ENDPOINT_URL=https://<cloudflare-account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=<r2-access-key-id>
# S3_SECRET_KEY='<r2-secret-access-key>'
# S3_BUCKET_RAW=nextballup-alpha-raw
# S3_REGION=auto

# ---- Auth / crypto ----
# Prefer path-based local keys so PEM newlines do not fight shell env parsing.
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PLAYBACK_TOKEN_EXPIRE_SECONDS=120
PLAYBACK_URL_EXPIRES_SECONDS=600
DEMO_PREVIEW_URL_EXPIRES_SECONDS=7200
CSRF_SECRET=local-alpha-csrf-secret-change-me-before-sharing
MFA_SECRET_KEY=local-alpha-mfa-secret-at-least-32-bytes

# ---- Email: local logs instead of Postmark ----
EMAIL_DELIVERY_PROVIDER=logging
EMAIL_DELIVERY_LOG_PATH=./local_artifacts/local_alpha/email_verification.jsonl
EMAIL_VERIFICATION_FROM_ADDRESS=kz@nextballup.com
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound

# ---- Billing / consent / alpha CV posture ----
BILLING_PROVIDER=billing_disabled
REQUIRE_PRIVACY_CONSENT_FOR_SENSITIVE_UPLOADS=true
REQUIRE_VERIFIED_EMAIL_FOR_SENSITIVE_ACTIONS=false
CV_PIPELINE_ENABLED=false
CV_DEMO_PREVIEW_ENABLED=false

# ---- Worker media: match Render's local ffmpeg path ----
WORKER_FFMPEG_BINARY=ffmpeg
WORKER_FFPROBE_BINARY=ffprobe
WORKER_MEDIA_SUBPROCESS_SANDBOX=true
WORKER_MEDIA_CONTAINER_SANDBOX_ENABLED=false
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=5

# ---- Upload tuning ----
MAX_UPLOAD_SIZE_BYTES=10737418240
UPLOAD_MULTIPART_THRESHOLD_BYTES=1073741824
UPLOAD_MULTIPART_PART_SIZE_BYTES=104857600
UPLOAD_URL_EXPIRES_SECONDS=3600

# ---- Observability ----
OBSERVABILITY_METRICS_ENABLED=false
OBSERVABILITY_WORKER_METRICS_ENABLED=false
OBSERVABILITY_METRICS_TOKEN=
