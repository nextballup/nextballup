# NextBallUp local alpha-like web profile.
#
# Copy to `apps/web/.env.alpha.local` and run:
#   scripts/local_alpha_web.sh

# Same-origin API calls still go through the Next.js rewrite.
NEXT_PUBLIC_API_URL=/api/v1

# Local API server started by scripts/local_alpha_api.sh.
API_UPSTREAM_URL=http://127.0.0.1:8000

# Keep landing/register UI aligned with local alpha backend profile.
NEXT_PUBLIC_REGISTRATION_MODE=invite_only

# Optional override for scripts/local_alpha_web.sh.
WEB_PORT=3000
