# URL the Next.js rewrite forwards /api/v1/* to. In local dev this is the API
# container on the host network; in production it is the internal ClusterIP /
# service DNS of the FastAPI deployment.
API_UPSTREAM_URL=http://127.0.0.1:8000

# Origin seen by the browser for API requests. Because of the rewrite above,
# this stays same-origin — do NOT change it to point at the backend directly
# unless you've re-audited the cookie / CSRF model for your deployment.
NEXT_PUBLIC_API_URL=/api/v1
