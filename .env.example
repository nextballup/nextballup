# NextBallUp — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://nextballup:nextballup_dev@127.0.0.1:5432/nextballup
DATABASE_URL_SYNC=postgresql://nextballup:nextballup_dev@127.0.0.1:5432/nextballup  # for Alembic

# ---- Redis ----
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ---- Object Storage (MinIO for dev, S3 for prod) ----
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_RAW=nbu-raw-video
S3_BUCKET_MEZZANINE=nbu-mezzanine
S3_BUCKET_HLS=nbu-hls
S3_BUCKET_CLIPS=nbu-clips
S3_BUCKET_THUMBNAILS=nbu-thumbnails
S3_BUCKET_REPORTS=nbu-reports
S3_REGION=us-east-1

# ---- Auth ----
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- App ----
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
CORS_ORIGINS=http://127.0.0.1:3000

# ---- CV Pipeline ----
CV_DEVICE=auto  # auto-detect: mps → cuda → cpu (never hardcode)
CV_BATCH_SIZE=4
CV_DETECTION_MODEL=rf-detr-l  # rf-detr-l, rf-detr-base, rf-detr-nano
CV_POSE_MODEL=vitpose-h  # vitpose-h, vitpose-b
CV_TRACKER=botsort  # botsort, bytetrack, ocsort (ONLY MIT-licensed trackers)
CV_JERSEY_OCR_MODEL=smolvlm2  # smolvlm2, tesseract
CV_TRACKING_FPS=10  # Process detection/tracking at 10fps (not 30) — 3× compute savings
CV_BALL_DETECTION_FPS=10  # Same rate as tracking to avoid frame alignment issues
# Ball detection runs a second 30fps pass automatically on ±3s windows around shot events only
CV_BALL_HIGHRES_WINDOW_SEC=3  # Seconds before/after shot events to re-run at 30fps

# ---- Apple Silicon (M5 Max) ----
PYTORCH_MPS_HIGH_WATERMARK_RATIO=0.7  # Prevent OOM on shared unified memory
# PYTORCH_MPS_FALLBACK_POLICY=error  # Uncomment during dev to catch CPU fallback ops

# ---- Court Registration ----
COURT_TYPE=nba  # nba, ncaa, fiba, highschool
COURT_LENGTH_FT=94
COURT_WIDTH_FT=50

# ---- Processing ----
MAX_UPLOAD_SIZE_BYTES=10737418240  # 10GB
TRANSCODE_TARGET_RESOLUTION=1920x1080
TRANSCODE_TARGET_FPS=30
TRANSCODE_TARGET_CODEC=h264

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000/ws
