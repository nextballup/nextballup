# NextBallUp — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://nextballup:nextballup_dev@127.0.0.1:5432/nextballup
DATABASE_URL_SYNC=postgresql://nextballup:nextballup_dev@127.0.0.1:5432/nextballup  # for Alembic
# In staging/production, set this to the non-owner CRUD-only role (migration
# 0008: `nextballup_app`) so request/worker traffic cannot bypass RLS as the
# table owner. Local dev may leave it unset and fall back to DATABASE_URL.
DATABASE_URL_RUNTIME=

# ---- Redis ----
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ---- Object Storage (MinIO for dev, S3 for prod) ----
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_RAW=nbu-raw-video
S3_BUCKET_MEZZANINE=nbu-mezzanine
S3_BUCKET_HLS=nbu-hls
S3_BUCKET_CLIPS=nbu-clips
S3_BUCKET_THUMBNAILS=nbu-thumbnails
S3_BUCKET_REPORTS=nbu-reports
S3_REGION=us-east-1

# ---- Auth ----
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CSRF_SECRET=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_HOST_PREFIX=false
COOKIE_DOMAIN=
# Staging/production default to requiring verified accounts for sensitive
# coach/admin mutations. Keep false only for local throwaway development.
REQUIRE_VERIFIED_EMAIL_FOR_SENSITIVE_ACTIONS=

# ---- Email Verification ----
# `logging` is for local/dev only. Staging/production fail closed unless this
# is set to a registered provider id such as `ses`, `sendgrid`, or `postmark`
# in deployment-specific wiring.
EMAIL_DELIVERY_PROVIDER=logging
EMAIL_DELIVERY_LOG_PATH=
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
EMAIL_VERIFICATION_REQUEST_RATE_ATTEMPTS=5
EMAIL_VERIFICATION_REQUEST_RATE_WINDOW_SECONDS=900
EMAIL_VERIFICATION_FROM_ADDRESS=no-reply@nextballup.invalid
EMAIL_VERIFICATION_REDIRECT_PATH=/verify-email

# ---- MFA ----
# Required in staging/production. Use at least 32 bytes of high-entropy secret
# material and store it in a secret manager, not in source control.
MFA_SECRET_KEY=
MFA_TOTP_ISSUER=NextBallUp
MFA_TOTP_STEP_SECONDS=30
MFA_TOTP_DIGITS=6
MFA_RECOVERY_CODE_COUNT=10

# ---- Billing ----
# `stub` is local/dev only. Staging/production fail closed unless this is set
# to a registered provider id such as `stripe`.
BILLING_PROVIDER=stub
BILLING_DEFAULT_PLAN_CODE=free

# ---- App ----
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000

# ---- Observability ----
# API metrics are token-gated. Worker metrics are per-process and loopback-only;
# scrape them from the worker host/container, not through the public API.
OBSERVABILITY_METRICS_ENABLED=false
OBSERVABILITY_METRICS_TOKEN=
OBSERVABILITY_WORKER_METRICS_ENABLED=false
OBSERVABILITY_WORKER_METRICS_HOST=127.0.0.1
OBSERVABILITY_WORKER_METRICS_PORT=9108
OBSERVABILITY_WORKER_METRICS_PORT_SPAN=16
CORS_ORIGINS=http://127.0.0.1:3000

# ---- Local demo preview bridge (dev/test only) ----
# Shells out to the sibling training repo to render an annotated MP4 preview
# for internal sanity checks. This is intentionally not a production runtime
# path and must stay disabled outside local/dev environments.
# Relative paths are resolved from the platform repo root, not the process CWD.
# Enabling this bridge also requires CELERY_BROKER_URL plus a worker consuming
# CELERY_CPU_QUEUE.
CV_DEMO_PREVIEW_ENABLED=false
CV_DEMO_PREVIEW_ROOT=./local_artifacts/demo_previews
CV_DEMO_TRAINING_REPO_ROOT=../nextballup-vision-training
CV_DEMO_CONFIG_PATH=../nextballup-vision-training/configs/experiments/basketball/detect/rfdetr_demo_local_overfit_v1.yaml
CV_DEMO_CHECKPOINT_PATH=../nextballup-vision-training/runs/bb_detect_rfdetr_demo_local_overfit_v1/demo-01/checkpoints/checkpoint_best_total.pth
CV_DEMO_SAMPLE_FPS=2
CV_DEMO_MAX_SAMPLE_FPS=4
CV_DEMO_TIMEOUT_SECONDS=1800
CV_DEMO_RETENTION_SECONDS=259200
CV_DEMO_SUBPROCESS_SANDBOX=true
CV_DEMO_MAX_CPU_SECONDS=0
CV_DEMO_MAX_OUTPUT_BYTES=0
CV_DEMO_MAX_OPEN_FILES=256

# ---- CV Pipeline ----
CV_PIPELINE_ENABLED=false
CV_REQUIRE_MODEL_ARTIFACTS=true
CV_MODEL_ARTIFACT_REQUIRED_STAGES=detection,tracking,court_mapping,events
CV_DEVICE=auto  # auto-detect: mps → cuda → cpu (never hardcode)
CV_BATCH_SIZE=4
CV_DETECTION_MODEL=rf-detr-l  # rf-detr-l, rf-detr-base, rf-detr-nano
CV_POSE_MODEL=vitpose-h  # vitpose-h, vitpose-b
CV_TRACKER=botsort  # botsort, bytetrack, ocsort (ONLY MIT-licensed trackers)
CV_JERSEY_OCR_MODEL=smolvlm2  # smolvlm2, tesseract
CV_TRACKING_FPS=10  # Process detection/tracking at 10fps (not 30) — 3× compute savings
CV_BALL_DETECTION_FPS=10  # Same rate as tracking to avoid frame alignment issues
# Ball detection runs a second 30fps pass automatically on ±3s windows around shot events only
CV_BALL_HIGHRES_WINDOW_SEC=3  # Seconds before/after shot events to re-run at 30fps

# ---- Apple Silicon (M5 Max) ----
PYTORCH_MPS_HIGH_WATERMARK_RATIO=0.7  # Prevent OOM on shared unified memory
# PYTORCH_MPS_FALLBACK_POLICY=error  # Uncomment during dev to catch CPU fallback ops

# ---- Court Registration ----
COURT_TYPE=nba  # nba, ncaa, fiba, highschool
COURT_LENGTH_FT=94
COURT_WIDTH_FT=50

# ---- Processing ----
MAX_UPLOAD_SIZE_BYTES=10737418240  # 10GB
TRANSCODE_TARGET_RESOLUTION=1920x1080
TRANSCODE_TARGET_FPS=30
TRANSCODE_TARGET_CODEC=h264
# Default behavior requires a current privacy/guardian consent ledger entry
# for youth, AAU, middle-school, high-school, and K-12 uploads. Set false only
# for local synthetic test data.
REQUIRE_PRIVACY_CONSENT_FOR_SENSITIVE_UPLOADS=true
RAW_VIDEO_RETENTION_DAYS=365
CSP_REPORT_RETENTION_DAYS=90
# Required for staging/production worker startup. Local dev can set false
# only when processing trusted synthetic clips.
WORKER_MEDIA_CONTAINER_SANDBOX_ENABLED=true
WORKER_MEDIA_CONTAINER_IMAGE=nextballup-ffmpeg-sandbox:6.1
WORKER_MEDIA_CONTAINER_CPUS=2.0
WORKER_MEDIA_CONTAINER_MEMORY=8g
WORKER_MEDIA_CONTAINER_PIDS_LIMIT=128
WORKER_STALE_HEARTBEAT_SECONDS=300
WORKER_MEDIA_MAX_CPU_SECONDS=7200
WORKER_MEDIA_MAX_OUTPUT_BYTES=107374182400

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000/ws
